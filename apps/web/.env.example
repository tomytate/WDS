# ═══════════════════════════════════════════════════════════════
# Wong Digital Shop - Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Service role key — never expose to the client, only used in server actions/cron
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Dashboard Admin ────────────────────────────────────────────
# Comma-separated list of emails allowed to access /dashboard
DASHBOARD_ADMIN_EMAILS=your-email@example.com

# ── Vercel ─────────────────────────────────────────────────────
# Blob storage for receipt file uploads
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Cloudflare Turnstile ───────────────────────────────────────
# Bot protection on order submission
# Get from: https://dash.cloudflare.com → Turnstile
# Test keys (always pass): site=1x00000000000000000000AA  secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Notifications ──────────────────────────────────────────────
# Telegram bot for order alerts
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100...
TELEGRAM_MESSAGE_THREAD_ID=

# Discord webhooks for order alerts (optional, two channels)
DISCORD_TRANSACTIONS_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
DISCORD_RECEIPT_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# ── Sentry ─────────────────────────────────────────────────────
# Error tracking and performance monitoring (optional)
SENTRY_AUTH_TOKEN=sntrys_...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Meta (Facebook) Pixel ──────────────────────────────────────
# Marketing analytics (optional)
NEXT_PUBLIC_META_PIXEL_ID=123456789...

# ── Vercel Edge Config ─────────────────────────────────────────
# Runtime feature flags (maintenance mode, order acceptance, boosting toggle)
EDGE_CONFIG=https://edge-config.vercel.com/...
EDGE_CONFIG_ID=ecfg_...

# ── Application ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://wongdigital.shop

# ── Discord Support & Ticketing ─────────────────────────────────
DISCORD_SUPPORT_WEBHOOK_URL=https://discord.com/api/webhooks/your_support_webhook_here

# ── Upstash Redis ──────────────────────────────────────────────
# Required in production for rate limiting. Get from: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Cron Jobs ──────────────────────────────────────────────────
# Secret used to authenticate Vercel Cron Job requests to /api/cron/*
CRON_SECRET=your-secret-here

# ── Resend (Transactional Email) ───────────────────────────────
# Order confirmation, processing, and delivery emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Optional: override the default sender address
# FROM_EMAIL=Wong Digital Shop <orders@wongdigital.shop>

# ── Payssion (Worldwide Payments) ──────────────────────────────
# Get from: https://payssion.com → Dashboard → API Keys
PAYSSION_API_KEY=your_api_key_here
PAYSSION_SECRET_KEY=your_secret_key_here
PAYSSION_LIVE=false

# ── Direct Database ───────────────────────────────────────────
# Only needed for seeding/migrations. Not required in production.
# DATABASE_URL=postgresql://postgres:password@host:6543/postgres