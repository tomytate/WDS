{
  "extends": "../../packages/config/tsconfig.next.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ],
      "@wongdigital/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@wongdigital/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@wongdigital/db": [
        "../../packages/db/src/index.ts"
      ],
      "@wongdigital/db/*": [
        "../../packages/db/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "e2e"
  ]
}
