{
  "name": "wongdigital-store",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "boosting:generate": "node scripts/generate-boosting-catalog.mjs",
    "db:seed": "bun --filter @wongdigital/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "postgres": "^3.4.9",
    "sharp": "0.34.5",
    "turbo": "2.9.6",
    "typescript": "6.0.2",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  },
  "overrides": {
    "typescript": "6.0.2"
  },
  "resolutions": {
    "typescript": "6.0.2"
  }
}
