{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DASHBOARD_ADMIN_EMAILS",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "BLOB_READ_WRITE_TOKEN",
        "SUPABASE_WEBHOOK_SECRET",
        "CRON_SECRET",
        "RECEIPT_RETENTION_DAYS",
        "TELEGRAM_BOT_TOKEN",
        "TELEGRAM_CHAT_ID",
        "TELEGRAM_MESSAGE_THREAD_ID",
        "NEXT_PUBLIC_TELEGRAM_SUPPORT_URL",
        "NEXT_PUBLIC_FACEBOOK_SUPPORT_URL",
        "VERCEL_URL",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "DISCORD_TRANSACTIONS_WEBHOOK_URL",
        "DISCORD_RECEIPT_WEBHOOK_URL",
        "DISCORD_SUPPORT_WEBHOOK_URL",
        "RESEND_API_KEY",
        "DATABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "PAYSSION_API_KEY",
        "PAYSSION_SECRET_KEY",
        "PAYSSION_LIVE",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "REDIS_URL"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    },
    "db:seed": {
      "cache": false
    }
  }
}
